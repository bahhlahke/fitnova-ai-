<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>SUPABASE_URL</key>
	<string>https://YOUR_PROJECT.supabase.co</string>
	<key>SUPABASE_ANON_KEY</key>
	<string>YOUR_ANON_KEY</string>
	<key>API_BASE_URL</key>
	<string>https://askkodaai.com</string>
	<key>CFBundleDisplayName</key>
	<string>Koda AI</string>
	<key>UILaunchScreen</key>
	<dict/>
	<key>NSHealthShareUsageDescription</key>
	<string>Koda AI syncs weight, sleep, and steps from Apple Health to your profile for better coaching and progress tracking.</string>
	<key>NSCameraUsageDescription</key>
	<string>Optional: capture body comp photos (front, side, back) for AI body fat estimation.</string>
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Choose photos for body comp scan and fridge scanner.</string>
</dict>
</plist>
